# MongoDB (Atlas example: ...mongodb.net/DATABASE_NAME?retryWrites=true&w=majority)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/chatapp?retryWrites=true&w=majority
MONGO_DATABASE=chatapp

# JWT signing secret — long random string (32+ chars)
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Exact origin of the Next.js app (CORS + cookies). No trailing slash.
# Local: http://localhost:3000  Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Optional: Render/Heroku set PORT; Spring Boot uses SERVER_PORT
# SERVER_PORT=8080
